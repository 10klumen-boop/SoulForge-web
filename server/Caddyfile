# SoulForge — soulfgonline.com (Spaceship DNS → VPS)
# A @ → 109.196.103.50
# A www → 109.196.103.50
#
# На VPS:
#   sudo apt install -y caddy   # если ещё нет
#   sudo cp /var/www/soulforge/server/Caddyfile.example /etc/caddy/Caddyfile
#   sudo systemctl reload caddy

soulfgonline.com {
	encode gzip
	reverse_proxy 127.0.0.1:8787
}

www.soulfgonline.com {
	redir https://soulfgonline.com{uri} permanent
}
